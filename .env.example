# Copy to .env and fill in. Generate randoms with: openssl rand -base64 36

# --- Karakeep core ---
NEXTAUTH_SECRET=          # openssl rand -base64 36
MEILI_MASTER_KEY=         # openssl rand -base64 36 | tr -dc 'A-Za-z0-9'
NEXTAUTH_URL=http://localhost:3000
# KARAKEEP_VERSION=release
# INFERENCE_TEXT_MODEL=llama3.2
# INFERENCE_IMAGE_MODEL=gemma4:26b
# INFERENCE_JOB_TIMEOUT_SEC=180

# --- Karakeep API key (used by fetcher, tagger, bot) ---
# Created AFTER first login: open the UI -> Settings -> API Keys -> create.
KARAKEEP_TOKEN=

# --- Cobalt ---
# Must match the uuid in ./cobalt/keys.json (see README step 2).
COBALT_API_KEY=

# --- Telegram bot ---
TELEGRAM_BOT_TOKEN=       # from @BotFather
TELEGRAM_ALLOWLIST=       # your numeric chat id (from @userinfobot); comma-separated for several

# --- Tuning (optional) ---
# POLL_INTERVAL_SEC=45
# TAG_MODEL=llama3.2
# WHISPER_MODEL=small      # base (faster) / medium (more accurate)
