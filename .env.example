# Copy to .env and fill in. Keep hints on their OWN lines — never after `=`
# (these are read via env_file, so an inline comment can become part of the value).

# --- Karakeep core ---
# Generate: openssl rand -base64 36
NEXTAUTH_SECRET=
# Generate: openssl rand -base64 36 | tr -dc 'A-Za-z0-9'
MEILI_MASTER_KEY=
NEXTAUTH_URL=http://localhost:3000
# KARAKEEP_VERSION=release
# INFERENCE_TEXT_MODEL=llama3.2
# INFERENCE_IMAGE_MODEL=gemma4:26b
# INFERENCE_JOB_TIMEOUT_SEC=180

# --- Karakeep API key (used by fetcher, tagger, bot) ---
# Created AFTER first login: UI -> Settings -> API Keys -> create.
KARAKEEP_TOKEN=

# --- Cobalt ---
# Must match the uuid in ./cobalt/keys.json (see README step 1).
COBALT_API_KEY=

# --- Telegram bot ---
# Bot token from @BotFather:
TELEGRAM_BOT_TOKEN=
# Your numeric chat id from @userinfobot (comma-separated for several):
TELEGRAM_ALLOWLIST=

# --- Tuning (optional) ---
# POLL_INTERVAL_SEC=45
# TAG_MODEL=llama3.2
# WHISPER_MODEL=small
